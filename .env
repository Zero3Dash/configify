# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=configlab_db
DB_USER=configlab_user
DB_PASSWORD=YourStrongPasswordHere2026

# ── Session secret (random string, min 32 chars) ───────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32

# ── Credential vault encryption key (MUST be 64 hex chars = 32 bytes) ─
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32_hex

# ── Application URL ────────────────────────────────────────────
APP_URL=https://configlab.yourdomain.com
